# ═════════════════════════════════════════════════════════════════════════════
# Copy this file to .env (which is .gitignored) and fill in real values, then:
#
#   set -a; source .env; set +a
#
# This exports the variables so Terragrunt / OpenTofu pick them up. OpenTofu
# reads any TF_VAR_<name> environment variable as the value for variable <name>.
#
# Never commit .env — it contains secrets.
# ═════════════════════════════════════════════════════════════════════════════

# ── Secrets ───────────────────────────────────────────────────────────────────
# Hetzner Cloud API token (Read & Write). Console → Security → API Tokens.
export TF_VAR_hcloud_token="YOUR_HCLOUD_API_TOKEN"

# Cloudflare API token, scoped to Zone.DNS:Edit on heinle.cc only.
export TF_VAR_cloudflare_api_token="YOUR_CLOUDFLARE_API_TOKEN"

# ── Account-specific (non-secret) ─────────────────────────────────────────────
# Cloudflare Zone ID for heinle.cc. Dashboard → heinle.cc → Overview → Zone ID.
export TF_VAR_cloudflare_zone_id="YOUR_CLOUDFLARE_ZONE_ID_FOR_HEINLE_CC"

# Email for the Let's Encrypt ACME account (expiry warnings).
export TF_VAR_letsencrypt_email="you@example.com"

# ── Optional overrides ────────────────────────────────────────────────────────
# Most tunables (cluster_name, location, node sizes, lb_type, base_domain) are
# set centrally in terragrunt.hcl. Override any of them here if you prefer, e.g.:
# export TF_VAR_agent_count="4"
# export TF_VAR_location="fsn1"
#
# SSH key paths default to ~/.ssh/id_ed25519[.pub]; override if different:
# export TF_VAR_ssh_public_key_path="$HOME/.ssh/id_ed25519.pub"
# export TF_VAR_ssh_private_key_path="$HOME/.ssh/id_ed25519"
