# ── OpenTofu / Terraform state ────────────────────────────────────────────────
# Never commit; contains plaintext secrets and resource IDs.
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
# Local backend state directory (Terragrunt writes here — see terragrunt.hcl).
state/

# ── Terragrunt ────────────────────────────────────────────────────────────────
# Per-unit working copies and generated files, rebuilt on every run.
.terragrunt-cache/
# Backend file generated by the root remote_state block.
backend.tf

# ── OpenTofu / Terraform working dirs ─────────────────────────────────────────
.terraform/
.terraform.lock.hcl

# ── Secrets / mise local config ───────────────────────────────────────────────
# Real secrets live in .mise.local.toml (TF_VAR_* entries); the .example IS committed.
.mise.local.toml
!.mise.local.toml.example
# Legacy *.tfvars and .env (kept ignored in case any are created locally).
*.tfvars
!*.tfvars.example
.env

# ── Kubeconfig written after cluster creation ─────────────────────────────────
kubeconfig.yaml

# ── Crash and debug logs ──────────────────────────────────────────────────────
crash.log
crash.*.log

# ── Override files (local developer customisations, not for VCS) ──────────────
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── macOS / IDE noise ─────────────────────────────────────────────────────────
.DS_Store
.idea/
*.swp
