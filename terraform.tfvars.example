# Copy this file to terraform.tfvars (which is .gitignored) and fill in real values.
# Alternatively export TF_VAR_<name>=<value> in your shell.

# ── Required: Secrets ─────────────────────────────────────────────────────────
hcloud_token         = "YOUR_HCLOUD_API_TOKEN"
cloudflare_api_token = "YOUR_CLOUDFLARE_API_TOKEN"

# ── Required: Domain / cert ───────────────────────────────────────────────────
cloudflare_zone_id = "YOUR_CLOUDFLARE_ZONE_ID_FOR_HEINLE_CC"
letsencrypt_email  = "you@example.com"

# ── Optional: defaults are sensible for an eval ──────────────────────────────
# cluster_name        = "opendesk-eval"
# node_type           = "ccx43"      # 16 vCPU / 64 GB, x86 — do NOT use CAX (ARM)
# location            = "nbg1"
# base_domain         = "od.heinle.cc"
# cloudflare_zone_name = "heinle.cc"
# ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
# ssh_private_key_path = "~/.ssh/id_ed25519"
